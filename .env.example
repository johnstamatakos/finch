ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001

# Plaid bank sync
# Get credentials at https://dashboard.plaid.com
# PLAID_ENV options: sandbox | production
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# AI provider — set to "claude" or "ollama"
AI_PROVIDER=claude

# Claude settings (used when AI_PROVIDER=claude)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ollama / local model settings (used when AI_PROVIDER=ollama)
# Install Ollama: https://ollama.com  |  then: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Batch size for transaction analysis
# 80 is safe for Claude Haiku; use ~20 for smaller local models like Qwen 7B
AI_BATCH_SIZE=80
