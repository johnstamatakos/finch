ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001

# Plaid bank sync
# Get credentials at https://dashboard.plaid.com
# PLAID_ENV options: sandbox | production
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# SLM / Ollama (optional — set AI_PROVIDER=ollama to use instead of Claude)
# Install Ollama: https://ollama.com  |  then: ollama pull qwen2.5:7b
AI_PROVIDER=claude
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
